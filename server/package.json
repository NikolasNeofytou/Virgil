{
  "name": "tichu-cyprus-server",
  "version": "0.1.0",
  "private": true,
  "description": "Authoritative Tichu game server (Node.js + TypeScript + WebSockets)",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.43.0",
    "@sentry/node": "^8.0.0",
    "dotenv": "^16.4.5",
    "pino": "^9.1.0",
    "uuid": "^10.0.0",
    "ws": "^8.17.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "eslint": "^8.57.0",
    "tsx": "^4.9.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
